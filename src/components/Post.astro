---
import AuthorBadge from './AuthorBadge.astro';

interface Props {
    title: string;
    uploaded_at: Date;
    updated_at: Date;
    author_name?: string;
    author_avatar?: string;
    access_envelopes?: Record<string, string>;
}

const {
    title,
    uploaded_at,
    updated_at,
    author_name,
    author_avatar,
    access_envelopes,
} = Astro.props;
const serializedAccessEnvelopes = JSON.stringify(access_envelopes ?? null);
---
<div class="post-info">
    <div class="post-img"></div>
    <div class="post-content">
        <div class="post-title" data-title={ title }>{ title }</div>
        {author_name && author_avatar && (
            <AuthorBadge name={author_name} avatar={author_avatar} />
        )}
        <div class="post-main" data-access-envelopes={ serializedAccessEnvelopes }>
            <slot />
        </div>
        <div class="dates">
            <div class="uploaded-at">
                <div class="uploaded-at-label">Uploaded:</div>
                <div class="uploaded-at-utc" data-date={ uploaded_at.toISOString() }></div>
            </div>
            <div class="updated-at">
                <div class="updated-at-label">Updated:</div>
                <div class="updated-at-utc" data-date={ updated_at.toISOString() }></div>
            </div>
        </div>
    </div>
</div>
<style  is:global>
    .post-info {
        padding: 20px;
        display: flex;
        border: 1px solid rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.04);
        border-radius: 4px;
        margin-bottom: 25px;
    }
    .post-img {
        width: 200px;
        margin-right: 50px;
        text-align: center;
    }
    .post-content {
        width: calc(100% - 100px);
        overflow: hidden;
    }
    .post-title {
        font-weight: bold;
        font-size: 22px;
        letter-spacing: 0.03em;
        overflow: hidden;
        width: 658px;
        margin-right: 15px;
    }
    .dates {
        display: flex;
        font-family: Proxima Nova, sans-serif;
        font-size: 12px;
        opacity: 0.5;
        padding-top: 30px;
    }
    .uploaded-at {
        padding-right: 20px;
    }
    .uploaded-at-label {
        float: left;
        padding-right: 5px;
        text-transform: uppercase;
        font-size: 10px;
        font-family: Proxima Nova, sans-serif;
        font-weight: bold;
    }
    .uploaded-at-utc {
        text-transform: uppercase;
        font-size: 10px;
        font-family: Proxima Nova, sans-serif;
    }
    .updated-at {
        display: flex;
    }
    .updated-at-label {
        padding-right: 5px;
        text-align: center;
        text-transform: uppercase;
        font-size: 10px;
        font-family: Proxima Nova, sans-serif;
        font-weight: bold;
    }
    .updated-at-utc {
        text-align: center;
        text-transform: uppercase;
        font-size: 10px;
        font-family: Proxima Nova, sans-serif;
    }
</style>

<script>
    import { decrypt } from '../utils/crypto';
    import { animateElement } from '../utils/animation';

    const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ''));
    const legacyKey = new URLSearchParams(window.location.search).get('key')?.trim() ?? null;

    const parseAccessEnvelopes = (value: string | undefined): Record<string, string> | null => {
        if (!value || value === 'null') return null;

        try {
            const parsed = JSON.parse(value);
            if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
                return null;
            }

            return Object.entries(parsed).reduce<Record<string, string>>((acc, [kid, envelope]) => {
                if (typeof envelope === 'string') {
                    acc[kid] = envelope;
                }
                return acc;
            }, {});
        } catch {
            return null;
        }
    };

    const resolveBodyKey = async (accessEnvelopes: Record<string, string> | null): Promise<string | null> => {
        if (accessEnvelopes && Object.keys(accessEnvelopes).length > 0) {
            const kid = hashParams.get('kid')?.trim() ?? '';
            const communityKey = hashParams.get('key')?.trim() ?? '';

            if (!kid || !communityKey) {
                return null;
            }

            const envelope = accessEnvelopes[kid];
            if (!envelope) {
                return null;
            }

            try {
                return await decrypt(envelope, communityKey);
            } catch {
                return null;
            }
        }

        return legacyKey;
    };

    // Dates — localise to client timezone and locale.
    const fmt = new Intl.DateTimeFormat(navigator.language, {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone,
    });
    document.querySelectorAll<HTMLElement>('[data-date]').forEach(el => {
        const iso = el.dataset.date;
        if (iso) el.textContent = fmt.format(new Date(iso));
    });

    // Title
    const titleEl = document.querySelector<HTMLElement>('.post-title');
    if (titleEl) {
        titleEl.textContent = titleEl.dataset.title ?? titleEl.textContent ?? '';
        animateElement(titleEl);
    }

    // Body — content is always server-rendered via Markdown component.
    // If a valid decryption key is available, attempt to decrypt each text node
    // in place. Wrong or missing keys leave the encrypted content visible.
    const postMain = document.querySelector<HTMLElement>('.post-main');
    if (postMain) {
        const accessEnvelopes = parseAccessEnvelopes(postMain.dataset.accessEnvelopes);
        const bodyKey = await resolveBodyKey(accessEnvelopes);

        if (bodyKey) {
            const walker = document.createTreeWalker(postMain, NodeFilter.SHOW_TEXT);
            const nodes: Text[] = [];
            let n: Node | null;
            while ((n = walker.nextNode())) nodes.push(n as Text);

            await Promise.all(nodes.map(async (node) => {
                const value = node.textContent?.trim();
                if (value) {
                    try {
                        node.textContent = await decrypt(value, bodyKey);
                    } catch {
                        // Wrong key or not a ciphertext — leave as-is.
                    }
                }
            }));
        }

        animateElement(postMain);
    }
</script>
