---
interface Props {
  readonly name: string;
  readonly avatar: string;
}

const { name, avatar } = Astro.props;
---

<div class="author-badge">
  <img
    class="author-avatar"
    src={avatar}
    alt={`${name} avatar`}
    width="40"
    height="40"
    loading="lazy"
  />
  <span class="author-name">{name}</span>
</div>

<style>
  .author-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 18px;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.14);
    background: #f3f4f6;
    object-fit: cover;
    flex: 0 0 auto;
  }

  .author-name {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.62);
  }

  :global(.dark) .author-avatar {
    border-color: rgba(255, 255, 255, 0.18);
    background: #1f2937;
  }

  :global(.dark) .author-name {
    color: rgba(255, 255, 255, 0.64);
  }
</style>
