---
import ToggleTheme from './misc/ToggleTheme.astro';
import { siteNavRows } from '../data/siteLinks';
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-brand">
      <div class="header-logo">
        <a href="/" class="container-logo">
          <img src="/lb.svg" alt="Logo" class="logo-img" />
          <div class="logo-text">
            <span class="logo-lock">LOCK</span>
            <span class="logo-bit">BIT5.0</span>
          </div>
        </a>
      </div>

      <a href="/" class="header-title" aria-label="Leaked data">
        <img
          src="/leaker.svg"
          alt="Leaked data"
          class="header-title-image"
        />
      </a>
    </div>

    <div class="header-right">
      <nav class="header-nav" aria-label="Primary">
        {siteNavRows.flat().map((link) => (
          <a href={link.href} class="header-nav-link">{link.label}</a>
        ))}
      </nav>

      <div class="header-theme-toggle">
        <ToggleTheme />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: #ffffff;
    border-bottom: 1px solid #d8dae0;
  }

  :global(.dark) .site-header {
    background: #0f1018;
    border-bottom-color: #1f2130;
  }

  .header-inner {
    max-width: 1450px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px var(--page-gutter);
    gap: 28px;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
  }

  .header-logo {
    flex-shrink: 0;
  }

  .container-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    padding-top: 8px;
  }

  .logo-img {
    display: block;
    height: 30px;
    width: auto;
  }

  .logo-text {
    display: flex;
    align-items: center;
    font-weight: 700;
    line-height: 1;
    padding: 0 20px 10px;
  }

  .logo-lock {
    font-size: 20px;
    color: #111111;
    letter-spacing: 0;
  }

  :global(.dark) .logo-lock {
    color: #e8e8e8;
  }

  .logo-bit {
    background: var(--color-lockbit-red);
    color: #ffffff;
    font-size: 20px;
    padding: 4px 10px;
    border-radius: 4px;
    margin-left: 4px;
    letter-spacing: 0;
  }

  .header-title {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header-title-image {
    display: block;
    height: 50px;
    width: auto;
    max-width: 100%;
  }

  .header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
    min-width: 0;
  }

  .header-nav {
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: 10px 22px;
    justify-content: end;
    align-items: center;
  }

  .header-nav-link {
    color: rgba(0, 0, 0, 0.5);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.15;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.12s;
  }

  :global(.dark) .header-nav-link {
    color: rgba(255, 255, 255, 0.6);
  }

  .header-nav-link:hover {
    color: #111111;
  }

  :global(.dark) .header-nav-link:hover {
    color: #f3f4f6;
  }

  .header-theme-toggle {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  @media (max-width: 1280px) {
    .header-inner {
      gap: 24px;
    }

    .header-brand {
      gap: 20px;
    }

    .header-title-image {
      height: 44px;
    }

    .header-nav {
      gap: 8px 14px;
    }
  }

  @media (min-width: 1200px) and (max-width: 1730px) {
    .header-inner {
      max-width: 100%;
    }
  }

  @media (max-width: 980px) {
    .header-inner {
      flex-wrap: wrap;
      min-height: unset;
      padding: 12px var(--page-gutter);
      gap: 16px;
    }

    .header-right {
      width: 100%;
      justify-content: space-between;
    }

    .header-nav {
      grid-template-columns: repeat(2, max-content);
      justify-content: start;
    }
  }

  @media (max-width: 768px) {
    .header-brand {
      width: 100%;
      justify-content: space-between;
      gap: 16px;
    }

    .logo-lock,
    .logo-bit {
      font-size: 17px;
    }

    .logo-bit {
      padding: 3px 8px;
    }

    .header-title-image {
      height: 38px;
    }

    .header-nav {
      display: none;
    }
  }
</style>
